{
  "name": "better-caesar-extension",
  "version": "0.7.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs --target all",
    "build:chrome": "node scripts/build.mjs --target chrome",
    "build:firefox": "node scripts/build.mjs --target firefox",
    "dev": "node scripts/build.mjs --target chrome --watch",
    "icons": "node scripts/render-icons.mjs",
    "package:chrome": "npm run build:chrome && node scripts/package.mjs --target chrome",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src eslint-rules",
    "lint:fix": "eslint src eslint-rules --fix"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@types/chrome": "^0.0.292",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitest/ui": "^4.1.5",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "jsdom": "^29.1.1",
    "sharp": "^0.34.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@types/d3-scale": "^4.0.9",
    "d3-scale": "^4.0.2",
    "lit-html": "^3.3.2"
  }
}
